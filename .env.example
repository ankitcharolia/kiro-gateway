# ── Required ──────────────────────────────────────────────────────────
KIRO_GATEWAY_API_KEY=change-me

# ── CLI path ──────────────────────────────────────────────────────────
# Path or name of the Kiro CLI binary.
# Default is "kiro-cli" (the binary name shipped by Kiro).
# Override if your binary has a different name or is not on $PATH:
#   KIRO_CLI_PATH=kiro                       # older installs
#   KIRO_CLI_PATH=/usr/local/bin/kiro-cli    # absolute path
KIRO_CLI_PATH=kiro-cli

# ── Models ────────────────────────────────────────────────────────────
# Unknown-model handling: warn (default) | strict (404) | off (forward silently)
MODEL_VALIDATION=warn
# Optional alias=target pairs (comma-separated) mapping a hardcoded foreign
# model id to a real kiro-cli model, e.g. MODEL_ALIASES=gpt-4o=claude-sonnet-4.6
MODEL_ALIASES=
# Enforce max_tokens by capping the output (kiro-cli doesn't honor it over ACP).
# false (default) = no cap; true = stop at the limit (finish_reason=length).
# stop sequences are always enforced when a client supplies them.
ENFORCE_MAX_TOKENS=false

# ── Tool execution ────────────────────────────────────────────────────
# true  = auto-approve kiro-cli built-in tool runs (file edits, commands)
# false = answer-only (every tool permission request is denied)
ACP_TRUST_TOOLS=true
# How the OpenAI/Anthropic shims present kiro-cli's OWN built-in tool activity
# (web search, file read/edit, shell, …):
#   false (default) = surface it as inline, NON-executable reasoning text
#                     (interleaved with thinking, like kiro-cli's activity view;
#                     requires ACP_SURFACE_THINKING=true). Works with every
#                     harness — no "unavailable tool" errors.
#   true            = expose it as executable tool_calls / tool_use, mapped
#                     onto your declared tool names by kind (e.g. kiro's
#                     execute→Bash, read→Read) so recognisable, falling back to
#                     a canonical name. Only for ACP-aware UIs that merely
#                     display activity; can make harnesses that validate tool
#                     names error. (Display normalisation, not a client-side
#                     function-calling round-trip — kiro-cli runs the tool.)
# (The native /acp/chat route always surfaces a structured acp_tool_call.)
ACP_SURFACE_TOOL_CALLS=false
# Surface kiro-cli's reasoning/"thinking" AND its built-in tool activity (when
# ACP_SURFACE_TOOL_CALLS=false) on the OpenAI/Anthropic shims in each API's
# native reasoning shape (OpenAI reasoning_content / Responses reasoning items;
# Anthropic thinking blocks). Default true — additive, never changes the final
# answer. Set false to emit only the final answer.
ACP_SURFACE_THINKING=true
# Default session cwd (defaults to process cwd)
ACP_WORKSPACE_DIR=
# Optional ACP session "mode" (agent persona) selected on every session via
# session/set_mode. kiro-cli exposes modes on session/new — e.g. kiro_default
# (default), code, kiro_planner, kiro_guide. Empty = keep kiro-cli's default.
# An unknown value is accepted silently (session keeps its default).
KIRO_ACP_MODE=

# ── ACP subprocess spawn args ─────────────────────────────────────────
# Flags passed to `kiro-cli acp` at launch. All optional; leave blank to keep
# the default behaviour. The engine is always pinned explicitly (default v2).
# --agent-engine: v1 | v2 | v3. Pinned to v2 (kiro-cli's current default) so a
# future change to the default engine can't silently alter behaviour. v3 needs
# host-mediated auth the gateway does not implement (generation fails) — see
# the v3 auth issue; keep v2.
KIRO_ACP_ENGINE=v2
# --agent: name of a (custom) agent config to use for the first session.
KIRO_ACP_AGENT=
# --model: model id to select when starting the first session. NOTE: distinct
# from KIRO_ACP_MODE (agent persona). A per-request model still overrides this.
KIRO_ACP_MODEL=
# --effort: initial thinking effort — low | medium | high | xhigh | max.
KIRO_ACP_EFFORT=
# Escape hatch: extra raw args appended verbatim (shell-quoted), e.g.
# KIRO_ACP_EXTRA_ARGS="--verbose --trust-tools fs_read"
KIRO_ACP_EXTRA_ARGS=

# ── MCP servers (external tools kiro-cli runs itself) ─────────────────
# MCP is the only external-tool channel kiro-cli honors over ACP (the gateway
# never runs the tools — compliance preserved; mcpCapabilities.http=true).
#
# YOU USUALLY DON'T NEED THESE. Servers you add with `kiro-cli mcp add` (global
# ~/.kiro/settings/mcp.json or a per-agent config) are auto-loaded by kiro-cli
# on every ACP session — verified: they work even when the gateway sends an
# empty list. That is the recommended path. These vars are an OPTIONAL
# SUPPLEMENT: a server list the gateway injects on every session/new, ADDED on
# top of kiro-cli's own config. Empty (default) = rely on kiro-cli's config.
# (The gateway cannot read a *harness's* MCP config — the OpenAI/Anthropic APIs
# have no MCP channel.)
#
# Provide EITHER inline JSON via KIRO_MCP_SERVERS, OR a file path via
# KIRO_MCP_CONFIG. Each accepts an ACP mcpServers array (verbatim) or the
# common mcp.json object form ({"mcpServers": {"<name>": {...}}} or a bare
# {"<name>": {...}} map, normalised with the key as each entry's "name").
# An HTTP entry MUST carry type:"http" and headers as an ARRAY — the gateway
# normalises the common object form ({"Authorization":"Bearer …"}) to
# [{"name","value"}] automatically (a wrong shape makes kiro-cli's session/new
# silently block, verified against a live kiro-cli 2.12.1 probe).
# KIRO_MCP_SERVERS=[{"type":"http","name":"docs","url":"http://127.0.0.1:9000/mcp","headers":[]}]
KIRO_MCP_SERVERS=
# KIRO_MCP_CONFIG=/path/to/mcp.json
KIRO_MCP_CONFIG=
# Seconds cap for session/new WHEN MCP servers are registered, so a
# malformed/unreachable server fails fast instead of stalling every request for
# ACP_TIMEOUT (a fresh session is opened per request). Default 30.
MCP_INIT_TIMEOUT=30

# Seconds to await a JSON-RPC response
ACP_TIMEOUT=120
# Max bytes per ACP stdout line (16 MiB). Raise for very large tool outputs
# or completions in long-running agent turns.
ACP_STDIO_MAX_BYTES=16777216

# ── Server ────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Compliance ────────────────────────────────────────────────────────
# Enforces single-account; set false only for development
COMPLIANCE_MODE=true
