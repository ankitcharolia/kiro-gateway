PROXY_API_KEY=change-me

# Path or name of the Kiro CLI binary.
# Default is "kiro-cli" (the binary name shipped by Kiro).
# Override if your binary has a different name or is not on $PATH:
#   KIRO_CLI_PATH=kiro                       # older installs
#   KIRO_CLI_PATH=/usr/local/bin/kiro-cli    # absolute path
KIRO_CLI_PATH=kiro-cli

ACP_ENABLED=true
OPENAI_SHIM_ENABLED=true
ANTHROPIC_SHIM_ENABLED=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
