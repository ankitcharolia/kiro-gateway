// Put this configuration in ~/.config/kilo/kilo.jsonc
//
// IMPORTANT — for thinking/reasoning + tool-activity display:
//   - Select "Claude Opus 4.8" in Kilo Code's model picker.
//     kiro-cli emits thinking for opus but NOT for claude-sonnet-4.6 (verified).
//   - Kilo Code streams by default — no extra setting needed.
//   - The gateway surfaces reasoning via reasoning_content (ACP_SURFACE_THINKING=true,
//     the default). budgetTokens values below are advisory only — kiro-cli decides
//     whether to think based on the model, not the client param.
{
  "$schema": "https://kilo.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "change-me"
      },
      "models": {
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (thinking)",
          "contextWindow": 1000000,
          "maxTokens": 32000
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "contextWindow": 1000000,
          "maxTokens": 64000
        },
        "auto": {
          "name": "Auto",
          "contextWindow": 1000000,
          "maxTokens": 64000
        }
      }
    }
  },
  "permission": {
    "bash": "allow"
  }
}
