// Put this configuration in ~/.config/kilo/kilo.jsonc
//
// IMPORTANT — for thinking/reasoning + tool-activity display:
//   - Select "Claude Opus 4.8" in Kilo Code's model picker.
//     kiro-cli emits thinking for opus but NOT for claude-sonnet-4.6 (verified).
//   - Kilo Code streams by default — no extra setting needed.
//   - The gateway surfaces reasoning via reasoning_content (ACP_SURFACE_THINKING=true,
//     the gateway default).
//
// NOTE: thinking.budgetTokens / outputConfig.effort variants are forwarded to
// kiro-cli under _meta but are advisory only — kiro-cli decides whether to think
// based on the model, not the budget. They are kept for forward-compatibility
// and so the variant picker in Kilo Code's UI works.
{
  "$schema": "https://kilo.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "change-me"
      },
      "models": {
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (thinking)",
          "contextWindow": 1000000,
          "maxTokens": 32000,
          "variants": {
            "low":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 4000  } } },
            "medium": { "options": { "thinking": { "type": "enabled", "budgetTokens": 8000  } } },
            "high":   { "options": { "thinking": { "type": "enabled", "budgetTokens": 16000 } } },
            "max":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 32000 } } }
          }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "contextWindow": 1000000,
          "maxTokens": 64000
        },
        "auto": {
          "name": "Auto",
          "contextWindow": 1000000,
          "maxTokens": 64000
        }
      }
    }
  },
  "permission": {
    "bash": "allow"
  }
}
