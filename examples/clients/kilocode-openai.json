// Put this configuration in ~/.config/kilo/kilo.jsonc
//
// Reasoning/"thinking" display is MODEL-DEPENDENT: kiro-cli emits thinking for
// `claude-opus-4.8` but not for `claude-sonnet-4.6` (verified). Select the
// opus model to see reasoning. The `thinking.budgetTokens` values below are
// advisory — kiro-cli decides whether to think based on the model, not the
// budget — and the gateway surfaces reasoning via `reasoning_content`
// (requires ACP_SURFACE_THINKING=true, the gateway default).
{
  "$schema": "https://kilo.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "change-me"
      },
      "models": {
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "contextWindow": 1000000,
          "maxTokens": 64000,
          "variants": {
            "low":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 4000  } } },
            "medium": { "options": { "thinking": { "type": "enabled", "budgetTokens": 8000  } } },
            "high":   { "options": { "thinking": { "type": "enabled", "budgetTokens": 16000 } } },
            "max":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 32000 } } }
          }
        },
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8",
          "contextWindow": 1000000,
          "maxTokens": 32000,
          "variants": {
            "low":    { "options": { "outputConfig": { "effort": "low"    } } },
            "medium": { "options": { "outputConfig": { "effort": "medium" } } },
            "high":   { "options": { "outputConfig": { "effort": "high"   } } },
            "xhigh":  { "options": { "outputConfig": { "effort": "xhigh"  } } },
            "max":    { "options": { "outputConfig": { "effort": "max"    } } }
          }
        },
        "auto": {
          "name": "Auto",
          "contextWindow": 1000000,
          "maxTokens": 64000,
          "variants": {
            "low":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 4000  } } },
            "medium": { "options": { "thinking": { "type": "enabled", "budgetTokens": 8000  } } },
            "high":   { "options": { "thinking": { "type": "enabled", "budgetTokens": 16000 } } },
            "max":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 32000 } } }
          }
        }
      }
    }
  },
  "permission": {
    "bash": "allow"
  }
}