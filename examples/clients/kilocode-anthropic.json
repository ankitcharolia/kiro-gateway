// Put this configuration in ~/.config/kilo/kilo.jsonc
//
// IMPORTANT — for thinking/reasoning + tool-activity display:
//   - Select "Claude Opus 4.8" in Kilo Code's model picker.
//     kiro-cli emits thinking for opus but NOT for claude-sonnet-4.6 (verified).
//   - Kilo Code streams by default — no extra setting needed.
//   - The gateway surfaces reasoning as Anthropic thinking blocks
//     (ACP_SURFACE_THINKING=true, the gateway default).
//
// NOTE: the thinking.budgetTokens variants below are forwarded to kiro-cli
// under _meta but are NOT yet wired to kiro-cli's effort control (tracked in
// gateway issue #59), so per-request budget has no effect today — they are kept
// for Kilo Code's variant picker UI and forward-compatibility. To bias thinking
// depth now, set a session-wide default via KIRO_ACP_EFFORT on the gateway.
{
  "$schema": "https://kilo.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/anthropic",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000",
        "apiKey": "change-me"
      },
      "models": {
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (thinking)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "contextWindow": 1000000,
          "maxTokens": 32000,
          "variants": {
            "low":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 4000  } } },
            "medium": { "options": { "thinking": { "type": "enabled", "budgetTokens": 8000  } } },
            "high":   { "options": { "thinking": { "type": "enabled", "budgetTokens": 16000 } } },
            "max":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 32000 } } }
          }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "attachment": true,
          "reasoning": false,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "contextWindow": 1000000,
          "maxTokens": 64000
        },
        "auto": {
          "name": "Auto",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "contextWindow": 1000000,
          "maxTokens": 64000
        }
      }
    }
  },
  "permission": {
    "bash": "allow"
  }
}
