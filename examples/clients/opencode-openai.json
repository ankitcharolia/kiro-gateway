// Put this configuration in ~/.config/opencode/opencode.json
//
// OpenCode streams by default — no extra config needed for live reasoning display.
// Use claude-opus-4.8 to see thinking; kiro-cli does NOT emit thinking for sonnet.
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "change-me"
      },
      "models": {
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (thinking)",
          "limit": { "context": 1000000, "output": 32000 }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "limit": { "context": 1000000, "output": 64000 }
        },
        "auto": {
          "name": "Auto",
          "limit": { "context": 1000000, "output": 64000 }
        }
      }
    }
  }
}
