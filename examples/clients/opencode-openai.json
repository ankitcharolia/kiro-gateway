// Put this configuration in ~/.config/opencode/opencode.json
//
// OpenCode streams by default — no extra config needed for live reasoning display.
// Use claude-opus-4.8 to see thinking; kiro-cli does NOT emit thinking for sonnet.
//
// Per-model capability flags (custom OpenAI-compatible providers are NOT in
// OpenCode's models.dev database, so OpenCode reads capabilities from THIS
// config — omitting them disables image upload and the reasoning pane):
//   "attachment": true  → enables image/file upload for the model
//   "reasoning":  true  → enables OpenCode's reasoning/thinking display
//   "tool_call":  true  → advertises the model as tool-capable
// kiro-cli forwards base64 images and emits reasoning (opus) over the gateway,
// so these flags let OpenCode actually surface both.
//
// NOTE: the thinking.budgetTokens variants below are forwarded to kiro-cli
// under _meta but are NOT yet wired to kiro-cli's effort control (tracked in
// gateway issue #59), so per-request budget has no effect today — they are kept
// for the OpenCode variant picker and forward-compatibility. To bias thinking
// depth now, set a session-wide default via KIRO_ACP_EFFORT on the gateway.
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kiro (AWS)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "change-me"
      },
      "models": {
        "claude-opus-4.8": {
          "name": "Claude Opus 4.8 (thinking)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1000000, "output": 32000 },
          "variants": {
            "low":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 4000  } } },
            "medium": { "options": { "thinking": { "type": "enabled", "budgetTokens": 8000  } } },
            "high":   { "options": { "thinking": { "type": "enabled", "budgetTokens": 16000 } } },
            "max":    { "options": { "thinking": { "type": "enabled", "budgetTokens": 32000 } } }
          }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "attachment": true,
          "reasoning": false,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1000000, "output": 64000 }
        },
        "auto": {
          "name": "Auto",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "limit": { "context": 1000000, "output": 64000 }
        }
      }
    }
  }
}
