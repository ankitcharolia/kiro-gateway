[
  {
    "type": "json",
    "path": "~/.aws/sso/cache/kiro-auth-token.json",
    "comment": "Kiro IDE credentials (recommended). Only ONE entry is permitted in this file."
  }
]

// --- Other valid single-entry patterns (use only ONE at a time) ---

// Option 2: kiro-cli SQLite database
// [
//   {
//     "type": "sqlite",
//     "path": "~/.local/share/kiro-cli/data.sqlite3",
//     "comment": "kiro-cli SQLite DB. Only ONE entry permitted."
//   }
// ]

// Option 3: Direct refresh token
// [
//   {
//     "type": "refresh_token",
//     "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
//     "profile_arn": "arn:aws:codewhisperer:us-east-1:123456789012:profile/abc123",
//     "region": "us-east-1",
//     "comment": "Direct refresh token. Only ONE entry permitted."
//   }
// ]

// ⚠️  COMPLIANCE NOTE
// -------------------
// This gateway enforces SINGLE-ACCOUNT personal use only.
// Adding more than one entry to this file will cause a startup error.
// Multi-account failover (ACCOUNT_SYSTEM=true) is disabled in this fork.
// See COMPLIANCE.md for the full policy.
